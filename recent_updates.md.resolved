## 4. Main Dashboard Acknowledge Alert Additions ([frontend/src/app/dashboard/page.tsx](file:///C:/Users/MJSAIDHANUSH/.gemini/antigravity/scratch/smart-farm-assistant/frontend/src/app/dashboard/page.tsx))
This handles the new conditional Grayscale state for the daily updates. Only showing the major logical additions we inserted here for context:

```tsx
// Inside `export default function Dashboard()`
    const [acknowledgedAlerts, setAcknowledgedAlerts] = useState<string[]>([]);

    // ...

    // Under Daily State Updates Heading
    <h3 className="text-xl font-bold text-white mb-4 tracking-tight flex items-center justify-between">
        <span>Daily State Updates</span>
        {dailyUpdatesList.some(u => ['red', 'orange', 'yellow'].includes(u.alertColor) && !acknowledgedAlerts.includes(u.title)) && (
            <span className="relative flex h-3 w-3">
                <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                <span className="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
            </span>
        )}
    </h3>

    // ... 

    // Inside the map over `dailyUpdatesList`
    {dailyUpdatesList.map((update, idx) => {
        const isAcknowledged = acknowledgedAlerts.includes(update.title);
        return (
            <li
                key={idx}
                className={`flex items-start group cursor-pointer hover:bg-gray-800/30 p-2 -mx-2 rounded-xl transition-all ${isAcknowledged ? 'opacity-40 grayscale' : ''}`}
                onClick={() => handleUpdateClick(update)}
            >
                <span className={`${isAcknowledged ? 'bg-gray-800 text-gray-500 border-gray-700' : `${update.bg} ${update.text} border ${update.border}`} p-2 rounded-xl mr-3 text-sm shadow-inner mt-1 relative`}>
                    {update.state}
                    {!isAcknowledged && update.alertColor === 'red' && <span className="absolute -top-1 -right-1 flex h-2.5 w-2.5"><span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span><span className="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span></span>}
                    // ... Orange and Yellow badge renders
                </span>
                // ... Label Renders
            </li>
        )
    })}

    // ...

    // Inside the Modal Window rendering on `selectedUpdate`
    <button
        onClick={() => {
            if (!acknowledgedAlerts.includes(selectedUpdate.title)) {
                setAcknowledgedAlerts(prev => [...prev, selectedUpdate.title]);
            }
            setSelectedUpdate(null);
        }}
        className={`w-full py-4 px-6 rounded-xl font-bold transition-all text-lg ...`}
    >
        Acknowledge Alert Message
    </button>
